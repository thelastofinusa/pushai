{
  "name": "pushai",
  "version": "2.0.4",
  "description": "Ship commits at the speed of thought.",
  "bin": {
    "pai": "./dist/index.mjs",
    "pushai": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "pushout": "npm publish",
    "pushout-inc": "npm version patch --no-git-tag-version && pnpm pushout",
    "sync:providers": "tsx scripts/sync-provider-types.ts"
  },
  "homepage": "https://pushai.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/thelastofinusa/pushai.git",
